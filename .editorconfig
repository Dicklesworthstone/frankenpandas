root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml,md,json,toml}]
indent_size = 2

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

[*.jsonl]
insert_final_newline = false
